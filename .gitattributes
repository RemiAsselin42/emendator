# Normalize line endings: store text as LF, let Git handle checkout per-OS.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.ico binary
*.icns binary

# Lockfiles are generated; collapse diffs in review.
pnpm-lock.yaml linguist-generated=true
uv.lock linguist-generated=true
Cargo.lock linguist-generated=true
